bindClass("android.widget.LinearLayout");
bindClass("android.widget.TextView");
bindClass("android.widget.ImageView");
bindClass("android.graphics.Color");
bindClass("android.graphics.drawable.GradientDrawable");
bindClass("android.view.Gravity");
bindClass("android.view.View");
bindClass("android.content.Intent");
bindClass("android.content.ComponentName");
bindClass("android.content.pm.PackageManager");
bindClass("android.util.TypedValue");

var ctx = LL.getContext(), pm = ctx.getPackageManager();

// --- 1. CONFIGURATION (Configure limits, not fixed sizes) ---
var Q = "phone"; // <── APP NAME
var C = {
    // Sizing rules (Min, Max, and Scaling Ratio)
    iMin: 48,  iMax: 200, iRatio: 0.5,   // Icon takes ~50% of the smallest side
    tMin: 22,  tMax: 60,  tRatio: 0.15,  // Text scales based on the smallest side
    gapRatio: 0.08,                      // Gap between icon and text
    // Styling
    bg: "#44000000", bc: "#77FFFFFF", bw: 3, tc: "#FFFFFF"
};

// --- 2. FETCH APP DATA ---
var A = { n: Q, cn: null, icon: null };
var it = new Intent(Intent.ACTION_MAIN).addCategory(Intent.CATEGORY_LAUNCHER);
var ls = pm.queryIntentActivities(it, 0);
for (var i = 0; i < ls.size(); i++) {
    var ai = ls.get(i).activityInfo, nm = ls.get(i).loadLabel(pm).toString();
    if (nm.toLowerCase().indexOf(Q.toLowerCase()) > -1) {
        A = { n: nm, cn: new ComponentName(ai.packageName, ai.name), icon: null };
        break;
    }
}
if (A.cn) try { A.icon = pm.getActivityIcon(A.cn); } catch(e) {}

// --- 3. BUILD UI (NO WRAPPERS - Just 1 Box, 1 Icon, 1 Label) ---
var box = new LinearLayout(ctx);
box.setGravity(Gravity.CENTER); // Always keeps contents perfectly centered

var gd = new GradientDrawable();
gd.setColor(Color.parseColor(C.bg));
gd.setStroke(C.bw, Color.parseColor(C.bc));
box.setBackground(gd);
try { box.setBackgroundBlur(40, [100,100,100,100,100,100,100,100]); } catch(e) {}

var iv = new ImageView(ctx);
if (A.icon) iv.setImageDrawable(A.icon);
iv.setScaleType(ImageView.ScaleType.FIT_CENTER);
iv.setAdjustViewBounds(true);

var lb = new TextView(ctx);
lb.setText(A.n);
lb.setTextColor(Color.parseColor(C.tc));
lb.setGravity(Gravity.CENTER);
lb.setSingleLine(true);
try { lb.setEllipsize(android.text.TextUtils.TruncateAt.END); } catch(e) {}
try { lb.setShadowLayer(3, 0, 2, Color.parseColor("#80000000")); } catch(e) {}

box.addView(iv);
box.addView(lb);

// --- 4. RESPONSIVE AUTO-SCALING ENGINE ---
box.addOnLayoutChangeListener(new View.OnLayoutChangeListener({
    onLayoutChange: function(v, l, t, r, b, ol, ot, orr, ob) {
        var w = r - l, h = b - t;
        if (w === 0 || h === 0) return;

        // Auto-perfect pill radius (always perfectly rounded edges)
        var minor = Math.min(w, h);
        gd.setCornerRadius(minor / 2);

        // Layout Profile detection
        var isWide = w > h;
        box.setOrientation(isWide ? LinearLayout.HORIZONTAL : LinearLayout.VERTICAL);

        // Calculate constrained sizes based on available space
        var iSize = Math.max(C.iMin, Math.min(C.iMax, minor * C.iRatio));
        var tSize = Math.max(C.tMin, Math.min(C.tMax, minor * C.tRatio));
        var gap = Math.max(8, minor * C.gapRatio);

        // Apply Icon Size
        iv.setLayoutParams(new LinearLayout.LayoutParams(iSize, iSize));

        // Apply Gap and Text Size
        var lp = new LinearLayout.LayoutParams(-2, -2);
        if (isWide) {
            lp.setMargins(gap, 0, 0, 0); // Gap on left
        } else {
            lp.setMargins(0, gap, 0, 0); // Gap on top
        }
        lb.setLayoutParams(lp);
        
        // Use PX instead of SP to prevent system font scaling from breaking the math
        lb.setTextSize(TypedValue.COMPLEX_UNIT_PX, tSize); 
    }
}));

// --- 5. INTERACTION & ANIMATION ---
box.setClickable(true);
box.setOnTouchListener(new View.OnTouchListener({
    onTouch: function(v, e) {
        var a = e.getAction();
        if (a === 0) { // DOWN
            v.animate().scaleX(0.92).scaleY(0.92).setDuration(100).setInterpolator(new android.view.animation.DecelerateInterpolator()).start();
            v.setAlpha(0.7);
        } else if (a === 1 || a === 3) { // UP / CANCEL
            v.animate().scaleX(1.0).scaleY(1.0).setDuration(250).setInterpolator(new android.view.animation.OvershootInterpolator(1.5)).start();
            v.setAlpha(1.0);
        }
        return false;
    }
}));

box.setOnClickListener(new View.OnClickListener({
    onClick: function(v) {
        if (A.cn) try { 
            ctx.startActivity(new Intent(Intent.ACTION_MAIN).setComponent(A.cn).addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)); 
        } catch(e) {}
    }
}));

return box;
